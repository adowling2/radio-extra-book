# macOS / editor clutter
.DS_Store

# Large source/reference materials used during conversion.
# Keep these locally, but do not commit them to the lightweight repo.
references/

# LaTeX build products
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
